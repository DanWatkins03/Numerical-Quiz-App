@model IEnumerable<CRUDWebApp.Models.NumericalQuestions>

@{
    ViewData["Title"] = "Quiz Mode";
}

<h1>Quiz Mode</h1>

<p>Answer the questions below, then submit to see your score.</p>

<form asp-controller="Quiz" asp-action="Submit" method="post">
    @foreach (var item in Model)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5>@item.NumericalQuestion</h5>

                <p>
                    <strong>Category:</strong> @item.Category |
                    <strong>Difficulty:</strong> @item.Difficulty
                </p>

                <input type="hidden" name="questionIds" value="@item.Id" />

                <div class="form-group">
                    <label>Your Answer</label>
                    <input type="text" name="userAnswers" class="form-control" />
                </div>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Submit Quiz</button>
</form>